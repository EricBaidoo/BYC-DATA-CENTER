# Enable Rewrite Engine
RewriteEngine On

# Block direct access to core system subdirectories
RewriteRule ^(includes|database)($|/) - [F,L]

# 1. Enforce HTTPS in production (exclude localhost/127.0.0.1)
RewriteCond %{HTTP_HOST} !^localhost [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# 2. Prevent direct web access to sensitive files
# Protect config files, databases, sql schemas, logs, git, shell scripts, and dot files
<FilesMatch "\.(db|sql|log|sh|git|sqlite|example|env)$|^config\.php$|^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# 3. Redirect direct requests for *.php files to extensionless URLs
# E.g. /members.php?id=5 -> /members?id=5
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# 4. Internally route extensionless URLs to PHP files
# E.g. /members -> /members.php (preserving query string parameters)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^ %{REQUEST_URI}.php [L]
